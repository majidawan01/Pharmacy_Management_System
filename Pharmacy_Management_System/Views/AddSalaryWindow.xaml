<Window x:Class="Pharmacy_Management_System.Views.AddSalaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pay Salary"
        Height="440" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Pay Employee Salary"
                       FontSize="20" FontWeight="Bold" Foreground="#1A1A2E"/>
            <TextBlock Text="Select employee and enter salary details"
                       FontSize="13" Foreground="#888888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="24">
            <StackPanel>

                <!-- Employee -->
                <TextBlock Text="Select Employee *" FontSize="12"
                           Foreground="#555" Margin="0,0,0,6"/>
                <Border BorderBrush="#E0E0E0" BorderThickness="1"
                        CornerRadius="8" Background="#FAFAFA"
                        Margin="0,0,0,16">
                    <ComboBox x:Name="cmbEmployee" Height="40"
                              Padding="8,0" FontSize="13"
                              BorderThickness="0" Background="Transparent"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectionChanged="cmbEmployee_SelectionChanged"/>
                </Border>

                <!-- Amount -->
                <TextBlock Text="Salary Amount (AFN) *" FontSize="12"
                           Foreground="#555" Margin="0,0,0,6"/>
                <Border BorderBrush="#E0E0E0" BorderThickness="1"
                        CornerRadius="8" Background="#FAFAFA"
                        Margin="0,0,0,16">
                    <TextBox x:Name="txtAmount" Height="40"
                             Padding="12,0" FontSize="13"
                             BorderThickness="0" Background="Transparent"
                             VerticalContentAlignment="Center" Text="0"/>
                </Border>

                <!-- Month -->
                <TextBlock Text="Month" FontSize="12"
                           Foreground="#555" Margin="0,0,0,6"/>
                <Border BorderBrush="#E0E0E0" BorderThickness="1"
                        CornerRadius="8" Background="#FAFAFA"
                        Margin="0,0,0,16">
                    <TextBox x:Name="txtMonth" Height="40"
                             Padding="12,0" FontSize="13"
                             BorderThickness="0" Background="Transparent"
                             VerticalContentAlignment="Center"/>
                </Border>

                <!-- Paid Date -->
                <TextBlock Text="Paid Date" FontSize="12"
                           Foreground="#555" Margin="0,0,0,6"/>
                <Border BorderBrush="#E0E0E0" BorderThickness="1"
                        CornerRadius="8" Background="#FAFAFA"
                        Margin="0,0,0,16">
                    <DatePicker x:Name="dpPaidDate" Height="40"
                                Padding="8,0" FontSize="13"
                                BorderThickness="0" Background="Transparent"/>
                </Border>

                <!-- Notes -->
                <TextBlock Text="Notes" FontSize="12"
                           Foreground="#555" Margin="0,0,0,6"/>
                <Border BorderBrush="#E0E0E0" BorderThickness="1"
                        CornerRadius="8" Background="#FAFAFA">
                    <TextBox x:Name="txtNotes" Height="50"
                             Padding="12,8" FontSize="13"
                             BorderThickness="0" Background="Transparent"
                             TextWrapping="Wrap"/>
                </Border>

                <TextBlock x:Name="txtError" Foreground="#E24B4A"
                           FontSize="12" Visibility="Collapsed"
                           Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Cancel" Height="46"
                    Background="#F5F5F5" Foreground="#555555"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="0,0,8,0"
                    Click="btnCancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1" Content="💵 Pay Salary"
                    Height="46" Background="#1565C0" Foreground="White"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="8,0,0,0"
                    Click="btnSave_Click">
                
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>