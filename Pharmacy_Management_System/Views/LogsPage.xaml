<Page x:Class="Pharmacy_Management_System.Views.LogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F4F8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="10"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" FontSize="16" Margin="14,0,0,0"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="txtSearch" Grid.Column="1"
                             Height="44" Padding="10,0,14,0"
                             FontSize="14" BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             TextChanged="txtSearch_TextChanged"/>
                </Grid>
            </Border>

            <!-- Type Filter -->
            <Border Grid.Column="1" Background="White" CornerRadius="10"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    Margin="12,0,0,0">
                <ComboBox x:Name="cmbLogType" Height="44" Width="180"
                          Padding="8,0" FontSize="13"
                          BorderThickness="0" Background="Transparent"
                          SelectionChanged="cmbLogType_SelectionChanged"
                          SelectedIndex="0">
                    <ComboBoxItem Content="All Logs"/>
                    <ComboBoxItem Content="Delete"/>
                    <ComboBoxItem Content="Update"/>
                    <ComboBoxItem Content="Insert"/>
                    <ComboBoxItem Content="Login"/>
                </ComboBox>
            </Border>

            <!-- Date Filter -->
            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    Margin="12,0,0,0">
                <DatePicker x:Name="dpFilter" Height="44" Width="160"
                            Padding="8,0" FontSize="13"
                            BorderThickness="0" Background="Transparent"
                            SelectedDateChanged="dpFilter_Changed"/>
            </Border>
        </Grid>

        <!-- Stats Row -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    Padding="16" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📋" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtTotalLogs" Text="0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#1565C0"/>
                        <TextBlock Text="Total Logs" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="10"
                    Padding="16" Margin="8,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🗑️" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtDeleteLogs" Text="0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#E24B4A"/>
                        <TextBlock Text="Delete Logs" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    Padding="16" Margin="8,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✏️" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtUpdateLogs" Text="0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#F57C00"/>
                        <TextBlock Text="Update Logs" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="White" CornerRadius="10"
                    Padding="16" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="➕" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtInsertLogs" Text="0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#2E7D32"/>
                        <TextBlock Text="Insert Logs" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Logs Table -->
        <Border Grid.Row="2" Background="White" CornerRadius="12">
            <DataGrid x:Name="dgLogs"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F8F9FA"
                      FontSize="13"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      RowHeight="44">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F0F4F8"/>
                        <Setter Property="Foreground" Value="#555555"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Height" Value="44"/>
                        <Setter Property="Padding" Value="12,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Type" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="8,3"
                                        HorizontalAlignment="Left" Margin="8,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActionType}" Value="Delete">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActionType}" Value="Update">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActionType}" Value="Login">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding ActionType}"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActionType}" Value="Delete">
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionType}" Value="Update">
                                                        <Setter Property="Foreground" Value="#F57C00"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionType}" Value="Login">
                                                        <Setter Property="Foreground" Value="#1565C0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Table"
                                        Binding="{Binding TableName}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description}"
                                        Width="*"/>
                    <DataGridTextColumn Header="User"
                                        Binding="{Binding Username}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Date  Time"
                                        Binding="{Binding CreatedAt}"
                                        Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>