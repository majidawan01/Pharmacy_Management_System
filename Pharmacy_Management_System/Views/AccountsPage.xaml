<Page x:Class="Pharmacy_Management_System.Views.AccountsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F4F8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="10"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" FontSize="16" Margin="14,0,0,0"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="txtSearch" Grid.Column="1"
                             Height="44" Padding="10,0,14,0"
                             FontSize="14" BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             TextChanged="txtSearch_TextChanged"/>
                </Grid>
            </Border>

            <Button Grid.Column="1" Content="+ Add Account"
                    Height="44" Padding="20,0"
                    Background="#1565C0" Foreground="White"
                    FontSize="13" FontWeight="SemiBold"
                    Cursor="Hand" Margin="12,0,0,0"
                    Click="btnAddAccount_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Stats Row -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    Padding="16" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📒" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtTotalAccounts" Text="0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#1565C0"/>
                        <TextBlock Text="Total Accounts" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="10"
                    Padding="16" Margin="8,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💰" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtTotalReceivable" Text="AFN 0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#2E7D32"/>
                        <TextBlock Text="Total Receivable" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    Padding="16" Margin="8,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💸" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtTotalPayable" Text="AFN 0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#E24B4A"/>
                        <TextBlock Text="Total Payable" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="White" CornerRadius="10"
                    Padding="16" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚖️" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtNetBalance" Text="AFN 0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#F57C00"/>
                        <TextBlock Text="Net Balance" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Accounts Table -->
        <Border Grid.Row="2" Background="White" CornerRadius="12">
            <DataGrid x:Name="dgAccounts"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F8F9FA"
                      FontSize="13"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      RowHeight="44">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F0F4F8"/>
                        <Setter Property="Foreground" Value="#555555"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Height" Value="44"/>
                        <Setter Property="Padding" Value="12,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Company Name"
                                        Binding="{Binding CompanyName}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Type"
                                        Binding="{Binding AccountType}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Total Amount"
                                        Binding="{Binding TotalAmount}"
                                        Width="130"/>
                    <DataGridTextColumn Header="Paid Amount"
                                        Binding="{Binding PaidAmount}"
                                        Width="130"/>
                    <DataGridTextColumn Header="Remaining"
                                        Binding="{Binding RemainingAmount}"
                                        Width="130"/>
                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding AccountDate}"
                                        Width="120"/>
                    <DataGridTemplateColumn Header="Actions" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,0">
                                    <Button Content="💳 Pay" Width="60" Height="28"
                                            Background="#E8F5E9" BorderThickness="0"
                                            Cursor="Hand" Margin="0,0,4,0"
                                            FontSize="11"
                                            Tag="{Binding Id}"
                                            Click="btnPay_Click"/>
                                    <Button Content="🗑️" Width="32" Height="28"
                                            Background="#FFEBEE" BorderThickness="0"
                                            Cursor="Hand"
                                            Tag="{Binding Id}"
                                            Click="btnDelete_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>