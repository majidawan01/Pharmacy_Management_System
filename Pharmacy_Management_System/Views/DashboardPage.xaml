<Page x:Class="Pharmacy_Management_System.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Background="#F0F4F8">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Stats Cards Row 1 -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Today Sales -->
                <Border Grid.Column="0" Background="White" CornerRadius="12"
                        Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Today's Sales" FontSize="13"
                                       Foreground="#888888"/>
                            <Border Grid.Column="1" Background="#E8F5E9"
                                    CornerRadius="8" Padding="8,4">
                                <TextBlock Text="💰" FontSize="16"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="txtTodaySales" Text="AFN 0"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="#1565C0" Margin="0,8,0,4"/>
                        <TextBlock Text="Today's total sales" FontSize="11"
                                   Foreground="#AAAAAA"/>
                    </StackPanel>
                </Border>

                <!-- Today Purchase -->
                <Border Grid.Column="1" Background="White" CornerRadius="12"
                        Margin="6,0,6,0" Padding="20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Today's Purchase" FontSize="13"
                                       Foreground="#888888"/>
                            <Border Grid.Column="1" Background="#E3F2FD"
                                    CornerRadius="8" Padding="8,4">
                                <TextBlock Text="🛒" FontSize="16"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="txtTodayPurchase" Text="AFN 0"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="#0288D1" Margin="0,8,0,4"/>
                        <TextBlock Text="Today's total purchase" FontSize="11"
                                   Foreground="#AAAAAA"/>
                    </StackPanel>
                </Border>

                <!-- Stock Value -->
                <Border Grid.Column="2" Background="White" CornerRadius="12"
                        Margin="6,0,6,0" Padding="20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Stock Value" FontSize="13"
                                       Foreground="#888888"/>
                            <Border Grid.Column="1" Background="#FFF3E0"
                                    CornerRadius="8" Padding="8,4">
                                <TextBlock Text="📦" FontSize="16"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="txtStockValue" Text="AFN 0"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="#F57C00" Margin="0,8,0,4"/>
                        <TextBlock Text="Total stock value" FontSize="11"
                                   Foreground="#AAAAAA"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock -->
                <Border Grid.Column="3" Background="White" CornerRadius="12"
                        Margin="12,0,0,0" Padding="20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Low Stock" FontSize="13"
                                       Foreground="#888888"/>
                            <Border Grid.Column="1" Background="#FFEBEE"
                                    CornerRadius="8" Padding="8,4">
                                <TextBlock Text="⚠️" FontSize="16"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="txtLowStock" Text="0 Items"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="#E24B4A" Margin="0,8,0,4"/>
                        <TextBlock Text="Need to restock" FontSize="11"
                                   Foreground="#AAAAAA"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Stats Cards Row 2 -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="12"
                        Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Near Expiry" FontSize="13"
                                       Foreground="#888888"/>
                            <Border Grid.Column="1" Background="#FFF8E1"
                                    CornerRadius="8" Padding="8,4">
                                <TextBlock Text="⏰" FontSize="16"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="txtNearExpiry" Text="0 Items"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="#F9A825" Margin="0,8,0,4"/>
                        <TextBlock Text="Expiring within 30 days" FontSize="11"
                                   Foreground="#AAAAAA"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="12"
                        Margin="6,0,6,0" Padding="20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Expired Items" FontSize="13"
                                       Foreground="#888888"/>
                            <Border Grid.Column="1" Background="#FFEBEE"
                                    CornerRadius="8" Padding="8,4">
                                <TextBlock Text="❌" FontSize="16"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="txtExpired" Text="0 Items"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="#C62828" Margin="0,8,0,4"/>
                        <TextBlock Text="Already expired" FontSize="11"
                                   Foreground="#AAAAAA"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="12"
                        Margin="12,0,0,0" Padding="20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Total Medicines" FontSize="13"
                                       Foreground="#888888"/>
                            <Border Grid.Column="1" Background="#E8EAF6"
                                    CornerRadius="8" Padding="8,4">
                                <TextBlock Text="💊" FontSize="16"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="txtTotalMedicines" Text="0"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="#3949AB" Margin="0,8,0,4"/>
                        <TextBlock Text="Registered medicines" FontSize="11"
                                   Foreground="#AAAAAA"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Charts Row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sales Chart -->
                <Border Grid.Column="0" Background="White" CornerRadius="12"
                        Padding="20" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="📈 Last 7 Days Sales"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#1A1A2E" Margin="0,0,0,16"/>
                        <lvc:CartesianChart x:Name="salesChart"
                                            Height="200"
                                            Hoverable="False"
                                            DataTooltip="{x:Null}">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis x:Name="salesAxisX"
                                          Foreground="#888888"
                                          FontSize="10"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Foreground="#888888"
                                          FontSize="10"
                                          MinValue="0"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </StackPanel>
                </Border>

                <!-- Purchase Chart -->
                <Border Grid.Column="1" Background="White" CornerRadius="12"
                        Padding="20" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🛒 Last 7 Days Purchase"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#1A1A2E" Margin="0,0,0,16"/>
                        <lvc:CartesianChart x:Name="purchaseChart"
                                            Height="200"
                                            Hoverable="False"
                                            DataTooltip="{x:Null}">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis x:Name="purchaseAxisX"
                                          Foreground="#888888"
                                          FontSize="10"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Foreground="#888888"
                                          FontSize="10"
                                          MinValue="0"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom Row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Sales -->
                <Border Grid.Column="0" Background="White" CornerRadius="12"
                        Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Recent Sales" FontSize="15"
                                   FontWeight="SemiBold" Foreground="#1A1A2E"
                                   Margin="0,0,0,16"/>
                        <DataGrid x:Name="dgRecentSales"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="White"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F8F9FA"
                                  FontSize="13"
                                  CanUserAddRows="False"
                                  RowHeight="40">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Voucher No"
                                                    Binding="{Binding VoucherNo}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Customer"
                                                    Binding="{Binding CustomerName}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Amount"
                                                    Binding="{Binding TotalAmount}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Date"
                                                    Binding="{Binding SaleDate}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Alerts -->
                <Border Grid.Column="1" Background="White" CornerRadius="12"
                        Margin="12,0,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Alerts" FontSize="15"
                                   FontWeight="SemiBold" Foreground="#1A1A2E"
                                   Margin="0,0,0,16"/>

                        <Border Background="#FFEBEE" CornerRadius="8"
                                Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="⚠️ Low Stock Alert"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#C62828"/>
                                <TextBlock x:Name="txtLowStockAlert"
                                           Text="No low stock items"
                                           FontSize="12" Foreground="#E57373"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFF8E1" CornerRadius="8"
                                Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="⏰ Expiry Alert"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#F57F17"/>
                                <TextBlock x:Name="txtExpiryAlert"
                                           Text="No expiring items"
                                           FontSize="12" Foreground="#FFB300"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#E8F5E9" CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="💾 Backup Reminder"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#2E7D32"/>
                                <TextBlock Text="Take daily backup"
                                           FontSize="12" Foreground="#66BB6A"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>