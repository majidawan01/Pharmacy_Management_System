<Window x:Class="Pharmacy_Management_System.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shakir Ihsan - Pharmacy Management System"
        Height="660" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        ShowInTaskbar="True">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="60" ShadowDepth="0"
                          Opacity="0.6" Color="#000000"/>
    </Window.Resources>

    <Grid>
        <Border Background="#F0F4F8"/>

        <Ellipse Fill="#1565C0" Opacity="0.08" Width="600" Height="600"
                 HorizontalAlignment="Left" VerticalAlignment="Center"
                 Margin="-200,0,0,0"/>
        <Ellipse Fill="#0D47A1" Opacity="0.05" Width="400" Height="400"
                 HorizontalAlignment="Right" VerticalAlignment="Center"
                 Margin="0,0,-100,0"/>

        <Border x:Name="RootCard"
                Width="1020" Height="610"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="0"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="80" ShadowDepth="0"
                                  Opacity="0.8" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== LEFT PANEL ===== -->
                <Grid Grid.Column="0" Background="#1A3A6B">

                    <Border Height="3" VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#42A5F5" Offset="0.5"/>
                                <GradientStop Color="#1565C0" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Border Width="1" HorizontalAlignment="Right"
                            Background="#1E2433"/>

                    <Grid Margin="36,40,36,36">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="56" Height="56"
                                    CornerRadius="12"
                                    BorderBrush="#1565C0"
                                    BorderThickness="1.5">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0D1B3E" Offset="0"/>
                                        <GradientStop Color="#1565C0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="💊" FontSize="26"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="SHAKIR IHSAN"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="WHOLE SELLER"
                                           FontSize="11" Foreground="#42A5F5"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Divider -->
                        <Border Grid.Row="1" Height="1"
                                Background="#1E2433"
                                Margin="0,24,0,0"/>

                        <!-- Info + Features -->
                        <StackPanel Grid.Row="2" Margin="0,24,0,0">

                            <!-- Location -->
                            <Border Background="#1E4A8A" CornerRadius="8"
                                    Padding="16,14" Margin="0,0,0,12"
                                    BorderBrush="#1E2433" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="6" Height="6"
                                                Background="#42A5F5"
                                                CornerRadius="3"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0"/>
                                        <TextBlock Text="LOCATION" FontSize="10"
                                                   FontWeight="Bold" Foreground="#42A5F5"/>
                                    </StackPanel>
                                    <TextBlock Text="Laghman Hada, Gulab Sehat Plaza"
                                               FontSize="12" Foreground="#E8F0FE"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="Shakir Ihsan Whole Seller"
                                               FontSize="12" Foreground="#8B9DC3"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Contact -->
                            <Border Background="#111827" CornerRadius="8"
                                    Padding="16,14" Margin="0,0,0,12"
                                    BorderBrush="#1E2433" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="6" Height="6"
                                                Background="#4CAF50"
                                                CornerRadius="3"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0"/>
                                        <TextBlock Text="CONTACT" FontSize="10"
                                                   FontWeight="Bold" Foreground="#4CAF50"/>
                                    </StackPanel>
                                    <TextBlock Text="+93 770 212 223"
                                               FontSize="12" Foreground="#8B9DC3"/>
                                    <TextBlock Text="+93 777 740 095"
                                               FontSize="12" Foreground="#8B9DC3"
                                               Margin="0,3,0,0"/>
                                    <TextBlock Text="+93 780 656 664"
                                               FontSize="12" Foreground="#8B9DC3"
                                               Margin="0,3,0,0"/>
                                    <TextBlock Text="+93 70 651 1413"
                                               FontSize="12" Foreground="#8B9DC3"
                                               Margin="0,3,0,0"/>
                                    <TextBlock Text="usman.fazli1000@gmail.com"
                                               FontSize="11" Foreground="#42A5F5"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Features -->
                            <Border Background="#111827" CornerRadius="8"
                                    Padding="16,14"
                                    BorderBrush="#1E2433" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="6" Height="6"
                                                Background="#FF9800"
                                                CornerRadius="3"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0"/>
                                        <TextBlock Text="SYSTEM FEATURES" FontSize="10"
                                                   FontWeight="Bold" Foreground="#FF9800"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="20" Height="20"
                                                Background="#0D1B3E" CornerRadius="4"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="🔒" FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Secure &amp; Encrypted"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#CBD5E1"/>
                                            <TextBlock Text="Military-grade data protection"
                                                       FontSize="10" Foreground="#BDD5F8"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="20" Height="20"
                                                Background="#0D1B3E" CornerRadius="4"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="📡" FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Offline &amp; Online"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#CBD5E1"/>
                                            <TextBlock Text="Works without internet"
                                                       FontSize="10" Foreground="#4A5568"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="20" Height="20"
                                                Background="#0D1B3E" CornerRadius="4"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="🌐" FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Multi Language"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#CBD5E1"/>
                                            <TextBlock Text="English · پښتو · دری · اردو"
                                                       FontSize="10" Foreground="#4A5568"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Footer -->
                        <StackPanel Grid.Row="3">
                            <Border Height="1" Background="#2A5AA0" Margin="0,0,0,12"/>
                            <TextBlock Text="© Afghan Cosmos IT &amp; Solutions"
                                       FontSize="10" Foreground="#90B8E8"/>
                            <TextBlock Text="Pharmacy Management System v1.0"
                                       FontSize="10" Foreground="#2D3748"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ===== RIGHT PANEL ===== -->
                <Grid Grid.Column="1" Background="#FFFFFF">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top accent -->
                    <Border Grid.Row="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#42A5F5" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Title Bar -->
                    <Grid Grid.Row="1" Background="White"
                          MouseDown="Panel_MouseDown">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0">
                            <Button x:Name="BtnMin" Content="—"
                                    Width="36" Height="28"
                                    Background="Transparent" BorderThickness="0"
                                    FontSize="13" Foreground="#999"
                                    Cursor="Hand" Click="BtnMin_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                                <Setter Property="Foreground" Value="#333"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="BtnMax" Content="◻"
                                    Width="36" Height="28"
                                    Background="Transparent" BorderThickness="0"
                                    FontSize="13" Foreground="#999"
                                    Cursor="Hand" Click="BtnMax_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                                <Setter Property="Foreground" Value="#333"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="BtnClose" Content="✕"
                                    Width="36" Height="28"
                                    Background="Transparent" BorderThickness="0"
                                    FontSize="13" Foreground="#999"
                                    Cursor="Hand" Click="BtnClose_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E24B4A"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Login Form -->
                    <Grid Grid.Row="2">
                        <StackPanel VerticalAlignment="Center"
                                    Margin="56,0,56,0">

                            <!-- Header -->
                            <StackPanel Margin="0,0,0,28">
                                <TextBlock Text="Welcome Back"
                                           FontSize="32" FontWeight="Bold"
                                           Foreground="#0D1117"/>
                                <TextBlock Text="Sign in to your pharmacy system"
                                           FontSize="13" Foreground="#94A3B8"
                                           Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- Language -->
                            <TextBlock Text="LANGUAGE" FontSize="10"
                                       FontWeight="Bold" Foreground="#94A3B8"
                                       Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="8"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Height="44" Margin="0,0,0,20">
                                <ComboBox x:Name="LangCombo"
                                          Background="Transparent" BorderThickness="0"
                                          Padding="12,0" FontSize="13"
                                          Foreground="#334155"
                                          VerticalContentAlignment="Center"
                                          SelectionChanged="LangCombo_SelectionChanged">
                                    <ComboBoxItem Content="Choose Language"
                                                  IsSelected="True" IsEnabled="False"/>
                                    <ComboBoxItem Content="English" Tag="en"/>
                                    <ComboBoxItem Content="پښتو (Pashto)" Tag="ps"/>
                                    <ComboBoxItem Content="دری (Dari)" Tag="da"/>
                                    <ComboBoxItem Content="اردو (Urdu)" Tag="ur"/>
                                    <ComboBoxItem Content="العربية (Arabic)" Tag="ar"/>
                                </ComboBox>
                            </Border>

                            <!-- Username -->
                            <TextBlock Text="USERNAME" FontSize="10"
                                       FontWeight="Bold" Foreground="#94A3B8"
                                       Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="8"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Height="48" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="0,0,1,0">
                                        <TextBlock Text="👤" FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBox x:Name="txtUsername" Grid.Column="1"
                                             BorderThickness="0" Background="Transparent"
                                             FontSize="14" Foreground="#0D1117"
                                             VerticalContentAlignment="Center"
                                             Padding="14,0"/>
                                </Grid>
                            </Border>

                            <!-- Password -->
                            <TextBlock Text="PASSWORD" FontSize="10"
                                       FontWeight="Bold" Foreground="#94A3B8"
                                       Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="8"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Height="48" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="0,0,1,0">
                                        <TextBlock Text="🔐" FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <PasswordBox x:Name="pwdBox" Grid.Column="1"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FontSize="14" Foreground="#0D1117"
                                                 VerticalContentAlignment="Center"
                                                 Padding="14,0"/>
                                    <TextBox x:Name="txtPasswordReveal" Grid.Column="1"
                                             BorderThickness="0" Background="Transparent"
                                             FontSize="14" Foreground="#0D1117"
                                             VerticalContentAlignment="Center"
                                             Padding="14,0" Visibility="Collapsed"/>
                                    <Button x:Name="BtnShow" Grid.Column="2"
                                            Content="👁" FontSize="16"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Foreground="#94A3B8"
                                            Click="BtnShow_Click"/>
                                </Grid>
                            </Border>

                            <!-- Error -->
                            <Border x:Name="borderError"
                                    Background="#FFF1F2" CornerRadius="8"
                                    BorderBrush="#FECDD3" BorderThickness="1"
                                    Padding="12,10" Visibility="Collapsed">
                                <TextBlock x:Name="txtError"
                                           Foreground="#E11D48" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <!-- Sign In Button -->
                            <Button x:Name="BtnSignIn"
                                    Height="50" Margin="0,20,0,0"
                                    Cursor="Hand" Click="BtnSignIn_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBg"
                                                Background="#1565C0" CornerRadius="8">
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="Sign In"
                                                           FontSize="15" FontWeight="Bold"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="  →" FontSize="18"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBg"
                                                        Property="Background"
                                                        Value="#0D47A1"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="btnBg"
                                                        Property="Background"
                                                        Value="#0A3D91"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Footer -->
                            <TextBlock Text="Powered by Afghan Cosmos IT &amp; Solutions"
                                       FontSize="11" Foreground="#CBD5E1"
                                       HorizontalAlignment="Center"
                                       Margin="0,20,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>