                                        <Border x:Name="navBorder" Background="Transparent"
                                                CornerRadius="8" Margin="10,1,10,1" Padding="12,10">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28"
                                                        Background="#E0F2FE" CornerRadius="6">
                                                    <TextBlock Text="📒" FontSize="14"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Accounts" FontSize="13"
                                                           Foreground="#334155" Margin="12,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal"/>
                                                    <VisualState x:Name="MouseOver">
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetName="navBorder"
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#F0F9FF" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- SYSTEM -->
                            <Border Height="1" Background="#E2E8F0"
                                    Margin="12,8,12,8"/>
                            <TextBlock Text="SYSTEM"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#94A3B8"
                                       Margin="20,0,0,8"/>

                            <!-- Logs -->
                            <Button x:Name="btnLogs" Tag="Logs"
                                    Click="NavButton_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="navBorder" Background="Transparent"
                                                CornerRadius="8" Margin="10,1,10,1" Padding="12,10">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28"
                                                        Background="#E0F2FE" CornerRadius="6">
