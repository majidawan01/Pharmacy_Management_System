                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="navBorder" Background="Transparent"
                                                CornerRadius="8" Margin="10,1,10,1" Padding="12,10">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28"
                                                        Background="#E0F2FE" CornerRadius="6">
