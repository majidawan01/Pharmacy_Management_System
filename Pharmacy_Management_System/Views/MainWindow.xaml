<Window x:Class="Pharmacy_Management_System.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shakir Ihsan - Pharmacy Management System"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MinHeight="600" MinWidth="1000">

    <Border CornerRadius="0" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== SIDEBAR ===== -->
            <Border Grid.Column="0" Background="#FFFFFF"
                    BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo Area -->
                    <Border Grid.Row="0" Background="#0EA5E9"
                            Padding="20,20,20,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="44" Height="44"
                                        CornerRadius="10"
                                        Background="White">
                                    <TextBlock Text="💊" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="SHAKIR IHSAN"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="White"/>
                                    <TextBlock Text="WHOLE SELLER"
                                               FontSize="10" Foreground="#BAE6FD"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Navigation -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Hidden"
                                  Margin="0,8,0,0">
                        <StackPanel>

                            <!-- MAIN MENU -->
                            <TextBlock Text="MAIN MENU"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#94A3B8"
                                       Margin="20,8,0,8"/>

                            <!-- Dashboard -->
                            <Button x:Name="btnDashboard" Tag="Dashboard"
                                    Click="NavButton_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="navBorder"
                                                Background="Transparent"
                                                CornerRadius="8"
                                                Margin="10,1,10,1"
                                                Padding="12,10">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28"
                                                        Background="#E0F2FE"
                                                        CornerRadius="6">
                                                    <TextBlock Text="📊" FontSize="14"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Dashboard"
                                                           FontSize="13"
                                                           Foreground="#334155"
                                                           Margin="12,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal"/>
                                                    <VisualState x:Name="MouseOver">
                                                        <Storyboard>
                                                            <ColorAnimation
                                                                Storyboard.TargetName="navBorder"
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#F0F9FF"
                                                                Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Medicines -->
                            <Button x:Name="btnMedicines" Tag="Medicines"
                                    Click="NavButton_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="navBorder" Background="Transparent"
                                                CornerRadius="8" Margin="10,1,10,1" Padding="12,10">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28"
                                                        Background="#E0F2FE" CornerRadius="6">
                                                    <TextBlock Text="💊" FontSize="14"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Medicines" FontSize="13"
                                                           Foreground="#334155" Margin="12,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal"/>
                                                    <VisualState x:Name="MouseOver">
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetName="navBorder"
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#F0F9FF" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Purchase -->
                            <Button x:Name="btnPurchase" Tag="Purchase"
                                    Click="NavButton_Click" Cursor="Hand">
