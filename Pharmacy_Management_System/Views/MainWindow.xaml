                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#F0F9FF" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Reports -->
                            <Button x:Name="btnReports" Tag="Reports"
                                    Click="NavButton_Click" Cursor="Hand">
                                <Button.Template>
