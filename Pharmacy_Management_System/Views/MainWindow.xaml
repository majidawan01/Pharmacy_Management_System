            <!-- ===== MAIN CONTENT ===== -->
            <Border Grid.Column="1" Background="#F1F5F9">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Bar -->
                    <Border Grid.Row="0" Background="White"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <Grid Margin="24,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="4" Height="20"
                                        Background="#0EA5E9" CornerRadius="2"
                                        Margin="0,0,12,0"/>
                                <TextBlock x:Name="txtPageTitle" Text="Dashboard"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="#0C4A6E"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <Border Background="#F0F9FF" CornerRadius="6"
                                        Padding="10,5" Margin="0,0,8,0"
                                        BorderBrush="#BAE6FD" BorderThickness="1">
                                    <TextBlock Text="Shakir Ihsan PMS"
                                               FontSize="11" Foreground="#0284C7"/>
                                </Border>

                                <Button Content="—" Width="36" Height="36"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="14" Foreground="#888"
                                        Cursor="Hand" Click="btnMinimize_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button x:Name="btnMaximize" Content="□"
                                        Width="36" Height="36"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="14" Foreground="#888"
                                        Cursor="Hand" Click="btnMaximize_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="✕" Width="36" Height="36"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="14" Foreground="#888"
                                        Cursor="Hand" Click="btnClose_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E24B4A"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content Frame -->
                    <Frame x:Name="MainFrame" Grid.Row="1"
                           NavigationUIVisibility="Hidden"
                           Background="#F1F5F9"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>