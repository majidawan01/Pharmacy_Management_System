                    <!-- Bottom User Panel -->
                    <Border Grid.Row="2" Background="#F0F9FF"
                            Margin="10,0,10,10" CornerRadius="10"
                            Padding="12,10" BorderBrush="#BAE6FD"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="34" Height="34"
                                    Background="#0EA5E9" CornerRadius="8">
                                <TextBlock Text="A" FontSize="16"
                                           FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Admin" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#0C4A6E"/>
                                <TextBlock Text="Administrator" FontSize="10"
                                           Foreground="#38BDF8"/>
                            </StackPanel>

                            <Button Grid.Column="2" Content="🚪"
                                    FontSize="16" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand"
                                    Foreground="#64748B"
                                    Click="btnLogout_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#E24B4A"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
