<Page x:Class="Pharmacy_Management_System.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F4F8">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="📊 Reports" FontSize="15"
                               FontWeight="Bold" Foreground="#1A1A2E"
                               Margin="16,0,0,16"/>

                    <!-- Sales -->
                    <TextBlock Text="SALES" FontSize="11" FontWeight="Bold"
                               Foreground="#AAAAAA" Margin="16,8,0,8"/>

                    <Button x:Name="btnSalesDaily" Tag="SalesDaily"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📅" FontSize="14"/>
                                        <TextBlock Text="Daily Sales" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="b"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#F0F4F8" Duration="0:0:0.1"/>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Normal"/>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnSalesWeekly" Tag="SalesWeekly"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📆" FontSize="14"/>
                                        <TextBlock Text="Weekly Sales" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnSalesMonthly" Tag="SalesMonthly"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗓️" FontSize="14"/>
                                        <TextBlock Text="Monthly Sales" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnSalesYearly" Tag="SalesYearly"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📈" FontSize="14"/>
                                        <TextBlock Text="Yearly Sales" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnSalesCustom" Tag="SalesCustom"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔍" FontSize="14"/>
                                        <TextBlock Text="Custom Sales" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Purchase -->
                    <TextBlock Text="PURCHASE" FontSize="11" FontWeight="Bold"
                               Foreground="#AAAAAA" Margin="16,16,0,8"/>

                    <Button x:Name="btnPurchaseDaily" Tag="PurchaseDaily"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📅" FontSize="14"/>
                                        <TextBlock Text="Daily Purchase" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnPurchaseMonthly" Tag="PurchaseMonthly"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗓️" FontSize="14"/>
                                        <TextBlock Text="Monthly Purchase" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnPurchaseYearly" Tag="PurchaseYearly"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📈" FontSize="14"/>
                                        <TextBlock Text="Yearly Purchase" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Stock -->
                    <TextBlock Text="STOCK" FontSize="11" FontWeight="Bold"
                               Foreground="#AAAAAA" Margin="16,16,0,8"/>

                    <Button x:Name="btnStockAll" Tag="StockAll"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📦" FontSize="14"/>
                                        <TextBlock Text="All Stock" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnStockLow" Tag="StockLow"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠️" FontSize="14"/>
                                        <TextBlock Text="Low Stock" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnStockExpiry" Tag="StockExpiry"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏰" FontSize="14"/>
                                        <TextBlock Text="Near Expiry" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Expenses -->
                    <TextBlock Text="EXPENSES" FontSize="11" FontWeight="Bold"
                               Foreground="#AAAAAA" Margin="16,16,0,8"/>

                    <Button x:Name="btnExpenseDaily" Tag="ExpenseDaily"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📅" FontSize="14"/>
                                        <TextBlock Text="Daily Expenses" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnExpenseMonthly" Tag="ExpenseMonthly"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗓️" FontSize="14"/>
                                        <TextBlock Text="Monthly Expenses" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnExpenseYearly" Tag="ExpenseYearly"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📈" FontSize="14"/>
                                        <TextBlock Text="Yearly Expenses" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Salary -->
                    <TextBlock Text="SALARY" FontSize="11" FontWeight="Bold"
                               Foreground="#AAAAAA" Margin="16,16,0,8"/>

                    <Button x:Name="btnSalaryReport" Tag="SalaryReport"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💵" FontSize="14"/>
                                        <TextBlock Text="Salary Report" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Debts -->
                    <TextBlock Text="DEBTS" FontSize="11" FontWeight="Bold"
                               Foreground="#AAAAAA" Margin="16,16,0,8"/>

                    <Button x:Name="btnDebtReport" Tag="DebtReport"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" FontSize="14"/>
                                        <TextBlock Text="Debt Report" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Master -->
                    <TextBlock Text="MASTER" FontSize="11" FontWeight="Bold"
                               Foreground="#AAAAAA" Margin="16,16,0,8"/>

                    <Button x:Name="btnMasterReport" Tag="MasterReport"
                            Click="ReportButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="14"/>
                                        <TextBlock Text="Master Report" FontSize="13"
                                                   Foreground="#444" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Content -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Report Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="txtReportTitle"
                               Text="Select a report from the left"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#1A1A2E"/>
                    <TextBlock x:Name="txtReportSubTitle"
                               Text="Click any report category to view data"
                               FontSize="13" Foreground="#888888"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="🖨️ Print Report"
                        Height="44" Padding="20,0"
                        Background="#1565C0" Foreground="White"
                        FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Click="btnPrint_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background"
                                            Value="#0D47A1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Date Filters -->
            <Border Grid.Row="1" Background="White" CornerRadius="12"
                    Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="From:" FontSize="13"
                               Foreground="#555" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Border Grid.Column="1" BorderBrush="#E0E0E0"
                            BorderThickness="1" CornerRadius="8"
                            Background="#FAFAFA" Margin="0,0,16,0">
                        <DatePicker x:Name="dpFrom" Height="38" Width="150"
                                    Padding="8,0" FontSize="13"
                                    BorderThickness="0" Background="Transparent"
                                    SelectedDateChanged="DateFilter_Changed"/>
                    </Border>

                    <TextBlock Grid.Column="2" Text="To:" FontSize="13"
                               Foreground="#555" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Border Grid.Column="3" BorderBrush="#E0E0E0"
                            BorderThickness="1" CornerRadius="8"
                            Background="#FAFAFA" Margin="0,0,16,0">
                        <DatePicker x:Name="dpTo" Height="38" Width="150"
                                    Padding="8,0" FontSize="13"
                                    BorderThickness="0" Background="Transparent"
                                    SelectedDateChanged="DateFilter_Changed"/>
                    </Border>

                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                        <Button Content="Today" Height="38" Padding="12,0"
                                Background="#E3F2FD" Foreground="#1565C0"
                                FontSize="12" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand"
                                Margin="0,0,8,0" Click="btnToday_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="This Week" Height="38" Padding="12,0"
                                Background="#E8F5E9" Foreground="#2E7D32"
                                FontSize="12" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand"
                                Margin="0,0,8,0" Click="btnThisWeek_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="This Month" Height="38" Padding="12,0"
                                Background="#FFF3E0" Foreground="#F57C00"
                                FontSize="12" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand"
                                Margin="0,0,8,0" Click="btnThisMonth_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="This Year" Height="38" Padding="12,0"
                                Background="#F3E5F5" Foreground="#7B1FA2"
                                FontSize="12" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand"
                                Click="btnThisYear_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Stats + Table -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Summary Cards -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White"
                            CornerRadius="12" Padding="16" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock x:Name="txtCard1Label" Text="Total Records"
                                       FontSize="12" Foreground="#888888"/>
                            <TextBlock x:Name="txtCard1Value" Text="0"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="#1565C0" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White"
                            CornerRadius="12" Padding="16" Margin="4,0,4,0">
                        <StackPanel>
                            <TextBlock x:Name="txtCard2Label" Text="Total Amount"
                                       FontSize="12" Foreground="#888888"/>
                            <TextBlock x:Name="txtCard2Value" Text="AFN 0"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="#2E7D32" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="White"
                            CornerRadius="12" Padding="16" Margin="4,0,4,0">
                        <StackPanel>
                            <TextBlock x:Name="txtCard3Label" Text="Paid Amount"
                                       FontSize="12" Foreground="#888888"/>
                            <TextBlock x:Name="txtCard3Value" Text="AFN 0"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="#F57C00" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="White"
                            CornerRadius="12" Padding="16" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock x:Name="txtCard4Label" Text="Remaining"
                                       FontSize="12" Foreground="#888888"/>
                            <TextBlock x:Name="txtCard4Value" Text="AFN 0"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="#E24B4A" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Data Table -->
                <Border Grid.Row="1" Background="White" CornerRadius="12">
                    <DataGrid x:Name="dgReport"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#F8F9FA"
                              FontSize="13"
                              CanUserAddRows="False"
                              RowHeight="44">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F0F4F8"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Height" Value="44"/>
                                <Setter Property="Padding" Value="12,0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>