<Window x:Class="Pharmacy_Management_System.Views.AddReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Return"
        Height="620" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Add Return"
                       FontSize="20" FontWeight="Bold" Foreground="#1A1A2E"/>
            <TextBlock Text="Fill in the return details below"
                       FontSize="13" Foreground="#888888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Return Type -->
                    <TextBlock Text="Return Type *" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="#FAFAFA"
                            Margin="0,0,0,16">
                        <ComboBox x:Name="cmbType" Height="40"
                                  Padding="8,0" FontSize="13"
                                  BorderThickness="0" Background="Transparent"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Customer Return"/>
                            <ComboBoxItem Content="Company Return"/>
                        </ComboBox>
                    </Border>

                    <!-- Voucher No -->
                    <TextBlock Text="Voucher No" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="#FAFAFA"
                            Margin="0,0,0,16">
                        <TextBox x:Name="txtVoucherNo" Height="40"
                                 Padding="12,0" FontSize="13"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 IsReadOnly="True"/>
                    </Border>

                    <!-- Party Name -->
                    <TextBlock Text="Customer / Company Name *" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="#FAFAFA"
                            Margin="0,0,0,16">
                        <TextBox x:Name="txtPartyName" Height="40"
                                 Padding="12,0" FontSize="13"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Medicine Search -->
                    <TextBlock Text="Medicine" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="White"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="txtMedicineSearch"
                                     Grid.Row="0"
                                     Height="40" Padding="12,0"
                                     FontSize="13" BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     TextChanged="txtMedicineSearch_TextChanged"
                                     KeyDown="txtMedicineSearch_KeyDown"/>
                            <Border Grid.Row="1"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="0,1,0,0"
                                    Background="White">
                                <ListBox x:Name="lstMedicineSuggestions"
                                         MaxHeight="150"
                                         Visibility="Collapsed"
                                         SelectionChanged="lstMedicineSuggestions_SelectionChanged"
                                         BorderThickness="0"
                                         Background="White"
                                         FontSize="13"
                                         Padding="4"
                                         KeyDown="lstMedicineSuggestions_KeyDown"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Amount -->
                    <TextBlock Text="Return Amount (AFN) *" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="#FAFAFA"
                            Margin="0,0,0,16">
                        <TextBox x:Name="txtAmount" Height="40"
                                 Padding="12,0" FontSize="13"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center" Text="0"/>
                    </Border>

                    <!-- Return Date -->
                    <TextBlock Text="Return Date" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="#FAFAFA"
                            Margin="0,0,0,16">
                        <DatePicker x:Name="dpReturnDate" Height="40"
                                    Padding="8,0" FontSize="13"
                                    BorderThickness="0" Background="Transparent"/>
                    </Border>

                    <!-- Notes -->
                    <TextBlock Text="Notes" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="#FAFAFA">
                        <TextBox x:Name="txtNotes" Height="50"
                                 Padding="12,8" FontSize="13"
                                 BorderThickness="0" Background="Transparent"
                                 TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock x:Name="txtError" Foreground="#E24B4A"
                               FontSize="12" Visibility="Collapsed"
                               Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Cancel" Height="46"
                    Background="#F5F5F5" Foreground="#555555"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="0,0,8,0"
                    Click="btnCancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1" Content="↩️ Save Return"
                    Height="46" Background="#00838F" Foreground="White"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="8,0,0,0"
                    Click="btnSave_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#006064"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>