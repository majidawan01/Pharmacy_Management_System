<Window x:Class="Pharmacy_Management_System.Views.AddPurchaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Purchase"
        Height="680" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Closing="Window_Closing"
        Background="#F0F4F8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="txtWindowTitle" Text="New Purchase"
                       FontSize="20" FontWeight="Bold" Foreground="#1A1A2E"/>
            <TextBlock Text="Enter purchase details and add medicines"
                       FontSize="13" Foreground="#888888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Purchase Info -->
        <Border Grid.Row="1" Background="White" CornerRadius="12"
                Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Voucher No" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="#FAFAFA">
                        <TextBox x:Name="txtVoucherNo" Height="40"
                                 Padding="12,0" FontSize="13"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 IsReadOnly="True"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="6,0,6,0">
                    <TextBlock Text="Supplier Name *" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="#FAFAFA">
                        <TextBox x:Name="txtSupplier" Height="40"
                                 Padding="12,0" FontSize="13"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="6,0,6,0">
                    <TextBlock Text="Purchase Date" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="#FAFAFA">
                        <DatePicker x:Name="dpPurchaseDate" Height="40"
                                    Padding="8,0" FontSize="13"
                                    BorderThickness="0" Background="Transparent"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="12,0,0,0">
                    <TextBlock Text="Paid Amount (AFN)" FontSize="12"
                               Foreground="#555" Margin="0,0,0,6"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Background="#FAFAFA">
                        <TextBox x:Name="txtPaidAmount" Height="40"
                                 Padding="12,0" FontSize="13"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Text="0"
                                 TextChanged="txtPaidAmount_TextChanged"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Items Section -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Purchase Items"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#1A1A2E" Margin="0,0,0,16"/>

                <!-- Add Item Row -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Medicine Search -->
                    <Border Grid.Column="0" BorderBrush="#E0E0E0"
                            BorderThickness="1" CornerRadius="8"
                            Background="White" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="txtMedicineSearch"
                                     Grid.Row="0"
                                     Height="40" Padding="12,0"
                                     FontSize="13" BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     TextChanged="txtMedicineSearch_TextChanged"
                                     KeyDown="txtMedicineSearch_KeyDown"/>
                            <Border Grid.Row="1"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="0,1,0,0"
                                    Background="White">
                                <ListBox x:Name="lstMedicineSuggestions"
                                         MaxHeight="150"
                                         Visibility="Collapsed"
                                         SelectionChanged="lstMedicineSuggestions_SelectionChanged"
                                         BorderThickness="0"
                                         Background="White"
                                         FontSize="13"
                                         Padding="4"
                                         KeyDown="lstMedicineSuggestions_KeyDown"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" BorderBrush="#E0E0E0"
                            BorderThickness="1" CornerRadius="8"
                            Background="#FAFAFA" Margin="0,0,8,0">
                        <TextBox x:Name="txtQty" Height="40"
                                 Padding="12,0" FontSize="13"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Text="1"
                                 TextChanged="txtQty_TextChanged"
                                 KeyDown="txtQty_KeyDown"/>
                    </Border>

                    <Border Grid.Column="2" BorderBrush="#E0E0E0"
                            BorderThickness="1" CornerRadius="8"
                            Background="#FAFAFA" Margin="0,0,8,0">
                        <TextBox x:Name="txtItemPrice" Height="40"
                                 Padding="12,0" FontSize="13"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Text="0"
                                 TextChanged="txtItemPrice_TextChanged"
                                 KeyDown="txtItemPrice_KeyDown"/>
                    </Border>

                    <Border Grid.Column="3" BorderBrush="#E0E0E0"
                            BorderThickness="1" CornerRadius="8"
                            Background="#F0F4F8" Margin="0,0,8,0">
                        <TextBox x:Name="txtItemTotal" Height="40"
                                 Padding="12,0" FontSize="13"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 IsReadOnly="True" Text="0"
                                 Foreground="#1565C0" FontWeight="SemiBold"/>
                    </Border>

                    <Button x:Name="btnAddItem" Grid.Column="4"
                            Content="+ Add"
                            Height="40" Padding="16,0"
                            Background="#1565C0" Foreground="White"
                            FontSize="13" FontWeight="SemiBold"
                            Cursor="Hand" Click="btnAddItem_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background"
                                                Value="#0D47A1"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Items List -->
                <DataGrid Grid.Row="2" x:Name="dgItems"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F8F9FA"
                          FontSize="13"
                          CanUserAddRows="False"
                          RowHeight="40"
                          Margin="0,8,0,0">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F0F4F8"/>
                            <Setter Property="Foreground" Value="#555555"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Height" Value="40"/>
                            <Setter Property="Padding" Value="12,0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Medicine"
                                            Binding="{Binding MedicineName}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Quantity"
                                            Binding="{Binding Quantity}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Price"
                                            Binding="{Binding Price}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Total"
                                            Binding="{Binding Total}"
                                            Width="100"/>
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Width="28" Height="28"
                                            Background="#FFEBEE"
                                            BorderThickness="0"
                                            Cursor="Hand" FontSize="12"
                                            Tag="{Binding MedicineId}"
                                            Click="btnRemoveItem_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Totals -->
        <Border Grid.Row="3" Background="White" CornerRadius="12"
                Padding="20" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtError" Foreground="#E24B4A"
                           FontSize="12" VerticalAlignment="Center"
                           Visibility="Collapsed" TextWrapping="Wrap"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <StackPanel Margin="0,0,32,0">
                        <TextBlock Text="Total Amount" FontSize="12"
                                   Foreground="#888888"/>
                        <TextBlock x:Name="txtTotalAmt" Text="AFN 0"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#1565C0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,32,0">
                        <TextBlock Text="Paid Amount" FontSize="12"
                                   Foreground="#888888"/>
                        <TextBlock x:Name="txtPaidAmt" Text="AFN 0"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#2E7D32"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Remaining" FontSize="12"
                                   Foreground="#888888"/>
                        <TextBlock x:Name="txtRemainingAmt" Text="AFN 0"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#E24B4A"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Cancel" Height="46"
                    Background="#F5F5F5" Foreground="#555555"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="0,0,8,0"
                    Click="btnCancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="btnEdit" Grid.Column="1"
                    Content="✏️ Edit Purchase"
                    Height="46" Background="#F57C00" Foreground="White"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="8,0,8,0"
                    Visibility="Collapsed"
                    Click="btnEdit_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#E65100"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="btnSave" Grid.Column="2"
                    Content="💾 Save Purchase"
                    Height="46" Background="#1565C0" Foreground="White"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="8,0,0,0"
                    Click="btnSave_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>