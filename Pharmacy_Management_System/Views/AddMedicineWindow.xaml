<Window x:Class="Pharmacy_Management_System.Views.AddMedicineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Medicine"
        Height="580" Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock x:Name="txtTitle" Text="Add New Medicine"
                       FontSize="20" FontWeight="Bold" Foreground="#1A1A2E"/>
            <TextBlock Text="Fill in the medicine details below"
                       FontSize="13" Foreground="#888888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Medicine Code -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
                        <TextBlock Text="Medicine Code" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtCode" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Medicine Name -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,16">
                        <TextBlock Text="Medicine Name *" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtName" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Generic Name -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,16">
                        <TextBlock Text="Generic Name" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtGenericName" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Company -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,16">
                        <TextBlock Text="Company" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtCompany" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Category -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,16">
                        <TextBlock Text="Category" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtCategory" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Unit -->
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="12,0,0,16">
                        <TextBlock Text="Unit (Tablet/Syrup/etc)" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtUnit" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Purchase Price -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,12,16">
                        <TextBlock Text="Purchase Price (AFN)" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtPurchasePrice" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Text="0"/>
                        </Border>
                    </StackPanel>

                    <!-- Sale Price -->
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="12,0,0,16">
                        <TextBlock Text="Sale Price (AFN)" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtSalePrice" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Text="0"/>
                        </Border>
                    </StackPanel>

                    <!-- Stock -->
                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,12,16">
                        <TextBlock Text="Opening Stock" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtStock" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Text="0"/>
                        </Border>
                    </StackPanel>

                    <!-- Min Stock -->
                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="12,0,0,16">
                        <TextBlock Text="Min Stock (Alert Level)" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtMinStock" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Text="10"/>
                        </Border>
                    </StackPanel>

                    <!-- Expiry Date -->
                    <StackPanel Grid.Row="5" Grid.Column="0"
                                Grid.ColumnSpan="2" Margin="0,0,0,16">
                        <TextBlock Text="Expiry Date" FontSize="12"
                                   Foreground="#555555" FontWeight="Medium"
                                   Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <DatePicker x:Name="dpExpiryDate" Height="40"
                                        Padding="8,0" FontSize="13"
                                        BorderThickness="0" Background="Transparent"
                                        VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Error -->
                    <TextBlock x:Name="txtError" Grid.Row="6"
                               Grid.ColumnSpan="2"
                               Foreground="#E24B4A" FontSize="12"
                               Visibility="Collapsed" Margin="0,0,0,8"
                               TextWrapping="Wrap"/>

                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Cancel" Height="46"
                    Background="#F5F5F5" Foreground="#555555"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="0,0,8,0"
                    Click="btnCancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1" x:Name="btnSave" Content="Save Medicine"
                    Height="46" Background="#1565C0" Foreground="White"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="8,0,0,0"
                    Click="btnSave_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background" Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>