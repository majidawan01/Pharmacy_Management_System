<Page x:Class="Pharmacy_Management_System.Views.ExpensesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F4F8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="10"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" FontSize="16" Margin="14,0,0,0"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="txtSearch" Grid.Column="1"
                             Height="44" Padding="10,0,14,0"
                             FontSize="14" BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             TextChanged="txtSearch_TextChanged"/>
                </Grid>
            </Border>

            <!-- Date Filter -->
            <Border Grid.Column="1" Background="White" CornerRadius="10"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    Margin="12,0,0,0">
                <DatePicker x:Name="dpFilter" Height="44" Width="160"
                            Padding="8,0" FontSize="13"
                            BorderThickness="0" Background="Transparent"
                            SelectedDateChanged="dpFilter_SelectedDateChanged"/>
            </Border>

            <Button Grid.Column="2" Content="+ Add Expense"
                    Height="44" Padding="20,0"
                    Background="#F57C00" Foreground="White"
                    FontSize="13" FontWeight="SemiBold"
                    Cursor="Hand" Margin="12,0,0,0"
                    Click="btnAddExpense_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#E65100"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Stats Row -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    Padding="16" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💸" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtTotalExpenses" Text="0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#F57C00"/>
                        <TextBlock Text="Total Expenses" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="10"
                    Padding="16" Margin="8,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📅" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtTodayExpenses" Text="AFN 0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#E24B4A"/>
                        <TextBlock Text="Today's Expenses" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    Padding="16" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💰" FontSize="24" Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="txtTotalAmount" Text="AFN 0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#1565C0"/>
                        <TextBlock Text="Total Amount" FontSize="12"
                                   Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Expenses Table -->
        <Border Grid.Row="2" Background="White" CornerRadius="12">
            <DataGrid x:Name="dgExpenses"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F8F9FA"
                      FontSize="13"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      RowHeight="44">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F0F4F8"/>
                        <Setter Property="Foreground" Value="#555555"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Height" Value="44"/>
                        <Setter Property="Padding" Value="12,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Title"
                                        Binding="{Binding Title}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Category"
                                        Binding="{Binding Category}"
                                        Width="150"/>
                    <DataGridTextColumn Header="Amount (AFN)"
                                        Binding="{Binding Amount}"
                                        Width="130"/>
                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding ExpenseDate}"
                                        Width="130"/>
                    <DataGridTextColumn Header="Notes"
                                        Binding="{Binding Notes}"
                                        Width="*"/>
                    <DataGridTemplateColumn Header="Actions" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,0">
                                    <Button Content="✏️" Width="32" Height="28"
                                            Background="#E3F2FD" BorderThickness="0"
                                            Cursor="Hand" Margin="0,0,4,0"
                                            Tag="{Binding Id}"
                                            Click="btnEdit_Click"/>
                                    <Button Content="🗑️" Width="32" Height="28"
                                            Background="#FFEBEE" BorderThickness="0"
                                            Cursor="Hand"
                                            Tag="{Binding Id}"
                                            Click="btnDelete_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>