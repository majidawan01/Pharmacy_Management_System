<Window x:Class="Pharmacy_Management_System.Views.AddEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Employee"
        Height="520" Width="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock x:Name="txtTitle" Text="Add New Employee"
                       FontSize="20" FontWeight="Bold" Foreground="#1A1A2E"/>
            <TextBlock Text="Fill in the employee details below"
                       FontSize="13" Foreground="#888888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Name -->
                    <StackPanel Grid.Row="0" Grid.Column="0"
                                Margin="0,0,12,16">
                        <TextBlock Text="Full Name *" FontSize="12"
                                   Foreground="#555" Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtName" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Phone -->
                    <StackPanel Grid.Row="0" Grid.Column="1"
                                Margin="12,0,0,16">
                        <TextBlock Text="Phone Number" FontSize="12"
                                   Foreground="#555" Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtPhone" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Address -->
                    <StackPanel Grid.Row="1" Grid.Column="0"
                                Grid.ColumnSpan="2" Margin="0,0,0,16">
                        <TextBlock Text="Address" FontSize="12"
                                   Foreground="#555" Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtAddress" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Salary -->
                    <StackPanel Grid.Row="2" Grid.Column="0"
                                Margin="0,0,12,16">
                        <TextBlock Text="Salary (AFN)" FontSize="12"
                                   Foreground="#555" Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <TextBox x:Name="txtSalary" Height="40"
                                     Padding="12,0" FontSize="13"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Text="0"/>
                        </Border>
                    </StackPanel>

                    <!-- Join Date -->
                    <StackPanel Grid.Row="2" Grid.Column="1"
                                Margin="12,0,0,16">
                        <TextBlock Text="Join Date" FontSize="12"
                                   Foreground="#555" Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <DatePicker x:Name="dpJoinDate" Height="40"
                                        Padding="8,0" FontSize="13"
                                        BorderThickness="0" Background="Transparent"/>
                        </Border>
                    </StackPanel>

                    <!-- Status -->
                    <StackPanel Grid.Row="3" Grid.Column="0"
                                Grid.ColumnSpan="2" Margin="0,0,0,16">
                        <TextBlock Text="Status" FontSize="12"
                                   Foreground="#555" Margin="0,0,0,6"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Background="#FAFAFA">
                            <ComboBox x:Name="cmbStatus" Height="40"
                                      Padding="8,0" FontSize="13"
                                      BorderThickness="0" Background="Transparent"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Active"/>
                                <ComboBoxItem Content="Inactive"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>

                    <!-- Error -->
                    <TextBlock x:Name="txtError" Grid.Row="4"
                               Grid.ColumnSpan="2"
                               Foreground="#E24B4A" FontSize="12"
                               Visibility="Collapsed" TextWrapping="Wrap"/>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Cancel" Height="46"
                    Background="#F5F5F5" Foreground="#555555"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="0,0,8,0"
                    Click="btnCancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1" x:Name="btnSave"
                    Content="Save Employee" Height="46"
                    Background="#7B1FA2" Foreground="White"
                    FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="8,0,0,0"
                    Click="btnSave_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="#4A148C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>